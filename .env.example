# 이 파일을 복사하여 .env 로 이름을 바꾸고 값을 설정하세요.
# .env 파일은 .gitignore 에 의해 커밋되지 않습니다.

# DB 연결 문자열 (프로덕션 환경에서 반드시 설정)
# 로컬 개발 시에는 docker-compose.yml 의 기본값이 자동으로 사용됩니다.
DB_AUTH_CONNECTION=Host=localhost;Port=5435;Database=auth;Username=gameserver;Password=your_password
DB_COMMON_CONNECTION=Host=localhost;Port=5433;Database=common;Username=gameserver;Password=your_password
DB_GAME_CONNECTION=Host=localhost;Port=5434;Database=game;Username=gameserver;Password=your_password
